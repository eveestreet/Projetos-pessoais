import java.util.Random;
import java.util.Scanner;
/*Questão difícil, porém divertida */

public class Main10 {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Random random = new Random();
        System.out.println("Par ou ímpar?");
        String pI = scanner.next();

        int n;
        int pontos = 0;
        do {
            System.out.println("Digite um número inteiro até 10: (digite 0 se quiser parar de jogar)");
            n = scanner.nextInt();

            if (n == 0) {
                System.out.println("Encerrando o jogo...");
                break;
            }

            if (n < 0 || n > 10) {
                System.out.println("Número inválido, tente novamente");
                continue;
            }

            int rng = random.nextInt(11);
            System.out.println("O computador escolheu o número: " + rng);

            if (n % 2 == 0) {
                System.out.println("Seu número é par");
            } else {
                System.out.println("Seu número é ímpar");
            }

            int soma = n + rng;
            System.out.println("A soma dos números é: " + soma);

            if (soma % 2 == 0 && pI.equalsIgnoreCase("par")) {
                System.out.println("Você ganhou!");
                pontos++;
                System.out.println("Sua pontuação atual é: " + pontos);

            } else if (soma % 2 != 0 && pI.equalsIgnoreCase("ímpar")) {
                System.out.println("Você ganhou!");
                pontos++;
                System.out.println("Sua pontuação atual é: " + pontos);


            } else {
                System.out.println("Você perdeu!");
                if (pontos > 0) {
                    pontos--;
                    System.out.println("Sua pontuação atual é: " + pontos);
                }else{
                        pontos = 0;
                        System.out.println("Sua pontuação atual é: " + pontos);
                    }
                }

            System.out.println("Deseja continuar? (S/N)");
            char conf = scanner.next().charAt(0);
            if (conf != 'S' && conf != 's') {
                System.out.println("Encerrando o jogo, obrigado por jogar!");
                System.out.println("Sua pontuação fianl foi:" + pontos );
                break;

            } else {
                System.out.println("Continuando o jogo...");
                System.out.println("Sua pontuação atual é: " + pontos);
                continue;
            }

        } while (true);
        scanner.close();
    }
}
